{
  "name": "C# (.NET)",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-8.0-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/dotnet:2": { "version": "8.0" }
  },
  "mounts": [
    "source=${localEnv:HOME}/.nuget,target=/home/vscode/.nuget,type=bind,consistency=cached",
    { "source": "dotnet-cache", "target": "/cache", "type": "volume" }
  ],
  "containerEnv": { "DOTNET_CLI_TELEMETRY_OPTOUT": "1" },
  "forwardPorts": [5000, 5001],
  "remoteUser": "vscode"
}
